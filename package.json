{
  "name": "eden-flywheel",
  "version": "1.0.0",
  "description": "MCP server that captures AI coding sessions as training data for fine-tuning local models. The closed loop: use AI → capture → fine-tune → deploy better model → repeat.",
  "main": "dist/index.js",
  "bin": {
    "eden-flywheel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:verbose": "tsx src/index.ts --verbose",
    "start:quiet": "tsx src/index.ts --quiet",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-rentel/eden-flywheel.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "training-data",
    "fine-tuning",
    "lora",
    "mlx",
    "claude",
    "ai",
    "flywheel",
    "sft",
    "llm"
  ],
  "author": "Renaissance Intelligence <alex@renaissanceintelligence.ai>",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/alex-rentel/eden-flywheel/issues"
  },
  "homepage": "https://github.com/alex-rentel/eden-flywheel#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
